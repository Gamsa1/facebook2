<odoo>
    <record id="view_messenger_page_list" model="ir.ui.view">
        <field name="name">messenger.page.list</field>
        <field name="model">messenger.page</field>
        <field name="arch" type="xml">
            <list string="Messenger Pages">
                <field name="name"/>
                <field name="page_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_messenger_page_form" model="ir.ui.view">
        <field name="name">messenger.page.form</field>
        <field name="model">messenger.page</field>
        <field name="arch" type="xml">
            <form string="Messenger Page">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="page_id"/>
                        <field name="page_access_token" password="True"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_messenger_page" model="ir.actions.act_window">
        <field name="name">Messenger Pages</field>
        <field name="res_model">messenger.page</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>