<?xml version="1.0"?>
<odoo noupdate="1">

    <!-- Facebook Graph API Url Parameter -->
    <record id="facebook_api_url" model="ir.config_parameter">
        <field name="key">facebook.api.url</field>
        <field name="value">https://graph.facebook.com/v21.0/</field>
    </record>

    <!-- Meta App Secret: used to verify the X-Hub-Signature-256 on incoming webhooks -->
    <record id="facebook_app_secret" model="ir.config_parameter">
        <field name="key">facebook.app_secret</field>
        <field name="value"></field>
    </record>

    <!-- Verify Token: the string you paste into Meta's webhook setup screen -->
    <record id="facebook_webhook_verify_token" model="ir.config_parameter">
        <field name="key">facebook.webhook.verify_token</field>
        <field name="value">CHANGE-ME-odoo-leadgen-verify-token</field>
    </record>


    <!-- On a form's FIRST sync, how many days of lead history to pull.
         Prevents dragging in years of backlog. Set to 3650 to import everything. -->
    <record id="facebook_initial_sync_days" model="ir.config_parameter">
        <field name="key">facebook.initial_sync_days</field>
        <field name="value">30</field>
    </record>

</odoo>
